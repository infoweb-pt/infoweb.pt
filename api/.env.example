# Django core
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database — matches the db service defined in docker-compose.yml
DATABASE_URL=postgres://infoweb:changeme@db:5432/infoweb

# Individual DB credentials (used by the entrypoint healthcheck)
DB_NAME=infoweb
DB_USER=infoweb
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# CORS — set CORS_ALLOW_ALL_ORIGINS=False in production and list frontend domain(s).
# SmartQR qr-manage uses X-Manage-Token; allowlisted in settings (CORS_ALLOW_HEADERS).
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# SmartQR links
# Public short URL base should point to the API host that serves /q/<slug>.
SMARTQR_PUBLIC_BASE_URL=https://api.yourdomain.com
# Manage UI link base should point to the frontend stats page.
SMARTQR_FRONTEND_MANAGE_URL=https://yourdomain.com/free-tools/qr-manage
