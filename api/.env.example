# Django core
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database — matches the db service defined in docker-compose.yml
DATABASE_URL=postgres://infoweb:changeme@db:5432/infoweb

# Individual DB credentials (used by the entrypoint healthcheck)
DB_NAME=infoweb
DB_USER=infoweb
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# CORS — set to False in production and list your frontend domain(s)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com
